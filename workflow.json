    {
      "parameters": {
        "jsCode": "const html = $json.data || $json.body || '';\n\nconst titleMatch = html.match(new RegExp('<title[^>]*>(.*?)</title>', 'i'));\n\nconst title = titleMatch\n  ? titleMatch[1].replace(/\\s+/g, ' ').trim()\n  : 'Untitled material';\n\nlet content = html;\n\ncontent = content.replace(new RegExp('<script[\\\\s\\\\S]*?</script>', 'gi'), '');\ncontent = content.replace(new RegExp('<style[\\\\s\\\\S]*?</style>', 'gi'), '');\ncontent = content.replace(new RegExp('<svg[\\\\s\\\\S]*?</svg>', 'gi'), '');\ncontent = content.replace(new RegExp('<[^>]+>', 'g'), ' ');\ncontent = content.replaceAll('&nbsp;', ' ');\ncontent = content.replaceAll('&amp;', '&');\ncontent = content.replaceAll('&lt;', '<');\ncontent = content.replaceAll('&gt;', '>');\ncontent = content.replace(/\\s+/g, ' ');\ncontent = content.trim().slice(0, 12000);\n\nreturn [\n  {\n    json: {\n      chatId: $('Telegram Trigger').item.json.message.chat.id,\n      userId: $('Telegram Trigger').item.json.message.from.id,\n      url: $('Telegram Trigger').item.json.message.text.split(' ')[1],\n      title,\n      content\n    }\n  }\n];"
      },
