    {
      "parameters": {
        "jsCode": "const rows = $input.all();\n\nif (rows.length === 0) {\n  return [\n    {\n      json: {\n        chatId: $('Telegram Trigger').item.json.message.chat.id,\n        message: 'No active quiz found. Send /quiz first.'\n      }\n    }\n  ];\n}\n\nconst latest = rows[rows.length - 1].json;\n\nconst userAnswers = $('Telegram Trigger').item.json.message.text\n  .toUpperCase()\n  .trim();\n\nconst correctAnswers = latest.correctAnswers;\nconst explanations = JSON.parse(latest.explanations);\n\nlet correctCount = 0;\nconst feedback = [];\n\nfor (let i = 0; i < correctAnswers.length; i++) {\n  const userAnswer = userAnswers[i];\n  const correctAnswer = correctAnswers[i];\n\n  if (userAnswer === correctAnswer) {\n    correctCount++;\n    feedback.push(`${i + 1}. ✅ Correct`);\n  } else {\n    const exp = explanations[i];\n    feedback.push(\n      `${i + 1}. ❌ Your answer: ${userAnswer}. Correct: ${correctAnswer}\\nExplanation: ${exp.explanation}`\n    );\n  }\n}\n\nconst score = Math.round((correctCount / correctAnswers.length) * 100);\n\nreturn [\n  {\n    json: {\n      chatId: $('Telegram Trigger').item.json.message.chat.id,\n      message: `✅ Quiz completed!\n\nScore: ${score}%\n\n${feedback.join('\\n\\n')}`\n    }\n  }\n];"
      },
