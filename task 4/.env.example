# Runway configuration
RUNWAY_COUNT=3
# Comma-separated list; count must equal RUNWAY_COUNT
RUNWAY_LENGTHS_M=3500,2800,2000

# Resource limits
GATE_COUNT=10
GROUND_CREW_COUNT=5

# Separation times between consecutive operations on the same runway (seconds)
RUNWAY_SEPARATION_TAKEOFF=90
RUNWAY_SEPARATION_LANDING=90
RUNWAY_SEPARATION_MIXED=60

# Gate turnaround: how long a gate is occupied per flight (seconds)
GATE_TURNAROUND_TIME=1800

# Buffer time between a dependency completing and its dependent starting (seconds)
DEPENDENCY_BUFFER_TIME=900

# Operation durations (seconds)
ARRIVAL_DURATION=900
DEPARTURE_DURATION=600

# Maximum scheduling horizon from t=0 (seconds); default = 8 hours
MAX_SCHEDULING_HORIZON=28800
